{
  "name": "@frondruntime/core",
  "version": "0.0.2",
  "description": "Effect-powered Frond runtime core with MobX-facing node state.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "homepage": "https://frondruntime.dev",
  "bugs": {
    "url": "https://github.com/frondruntime/frond/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frondruntime/frond.git",
    "directory": "packages/core"
  },
  "keywords": [
    "effect",
    "frond",
    "mobx",
    "runtime",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "source": "./src/testing/index.ts",
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "CHANGELOG.md",
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "bun": ">=1"
  },
  "scripts": {
    "build": "bun ../../build.ts core",
    "prepack": "bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun --conditions=source test"
  },
  "peerDependencies": {
    "mobx": ">=6 <7",
    "effect": "^4.0.0-0"
  },
  "author": {
    "name": "Roman Dubinin",
    "url": "https://romanonthego.dev"
  },
  "devDependencies": {
    "effect": "4.0.0-beta.90",
    "mobx": "6.15.3"
  }
}
